// ============================================
// Database Schema Documentation
// ============================================
// This file documents the SQLite schema created by:
// src-tauri/kabegame-core/src/storage/migrations/init.rs
//
// It is NOT used to generate a Prisma client. Runtime database operations are
// handled directly through rusqlite in kabegame-core.
//
// Database: SQLite
// Location: {app_data_dir}/images.db
//
// Prisma cannot represent every SQLite construct used by the app. Unsupported
// indexes are documented inline near their models.
// ============================================

datasource db {
  provider = "sqlite"
}

/// 任务表
model Task {
  id            String  @id
  pluginId      String  @map("plugin_id")
  outputDir     String? @map("output_dir")
  userConfig    String? @map("user_config") // JSON string
  httpHeaders   String? @map("http_headers") // JSON string: Record<string,string>
  outputAlbumId String? @map("output_album_id")
  runConfigId   String? @map("run_config_id")
  triggerSource String  @default("manual") @map("trigger_source")
  status        String
  progress      Float   @default(0)
  deletedCount  Int     @default(0) @map("deleted_count")
  dedupCount    Int     @default(0) @map("dedup_count")
  successCount  Int     @default(0) @map("success_count")
  failedCount   Int     @default(0) @map("failed_count")
  startTime     Int?    @map("start_time")
  endTime       Int?    @map("end_time")
  error         String?

  images Image[] @relation("TaskToImage")

  @@index([startTime(sort: Desc)], name: "idx_tasks_start_time")
  @@map("tasks")
}

/// 插件详情 JSON 存储
model ImageMetadata {
  id       Int    @id @default(autoincrement())
  data     String // JSON string
  version  Int    @default(0)
  pluginId String @default("") @map("plugin_id")

  images           Image[]
  taskFailedImages TaskFailedImage[]

  @@index([pluginId, version], name: "idx_image_metadata_dedup")
  @@map("image_metadata")
}

/// 图片表（同时支持视频壁纸）
model Image {
  id                 Int     @id @default(autoincrement())
  url                String?
  localPath          String  @unique(map: "idx_images_local_path") @map("local_path")
  pluginId           String  @map("plugin_id")
  taskId             String? @map("task_id")
  surfRecordId       String? @map("surf_record_id")
  crawledAt          Int     @map("crawled_at")
  metadataId         Int?    @map("metadata_id")
  thumbnailPath      String  @default("") @map("thumbnail_path")
  hash               String  @default("")
  type               String? @default("image")
  width              Int?
  height             Int?
  displayName        String  @default("") @map("display_name")
  lastSetWallpaperAt Int?    @map("last_set_wallpaper_at")
  size               Int?
  description        String?
  compatiblePath     String? @map("compatible_path")

  task          Task?          @relation("TaskToImage", fields: [taskId], references: [id], onDelete: SetNull)
  imageMetadata ImageMetadata? @relation(fields: [metadataId], references: [id])

  @@index([crawledAt(sort: Desc)], name: "idx_crawled_at")
  @@index([pluginId], name: "idx_plugin_id")
  @@index([taskId], name: "idx_task_id")
  @@index([surfRecordId], name: "idx_images_surf_record_id")
  @@index([hash], name: "idx_images_hash")
  @@index([thumbnailPath], name: "idx_images_thumbnail_path")
  @@index([lastSetWallpaperAt(sort: Desc)], name: "idx_images_last_set_wallpaper_at")
  @@map("images")
}

/// 画册表
model Album {
  id           String  @id
  name         String
  createdAt    Int     @map("created_at")
  parentId     String? @map("parent_id")
  type         String  @default("normal")
  syncFolder   String? @unique(map: "idx_albums_sync_folder") @map("sync_folder")
  folderStatus String? @map("folder_status")

  parent   Album?  @relation("AlbumTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Album[] @relation("AlbumTree")

  // SQLite expression index not representable in Prisma:
  // CREATE UNIQUE INDEX idx_albums_name_scoped
  //   ON albums(COALESCE(parent_id, ''), LOWER(name));
  //
  // SQLite partial unique index represented above as nullable @unique:
  // CREATE UNIQUE INDEX idx_albums_sync_folder
  //   ON albums(sync_folder) WHERE sync_folder IS NOT NULL;
  @@map("albums")
}

/// 画册-图片关联表
model AlbumImage {
  albumId String @map("album_id")
  imageId Int    @map("image_id")
  order   Int?   @map("order")

  @@id([albumId, imageId])
  @@index([albumId], name: "idx_album_images_album")
  @@index([imageId], name: "idx_album_images_image")
  @@map("album_images")
}

/// 任务下载失败图片表
model TaskFailedImage {
  id              Int     @id @default(autoincrement())
  taskId          String  @map("task_id")
  pluginId        String  @map("plugin_id")
  url             String
  order           Int     @map("order")
  createdAt       Int     @map("created_at")
  lastError       String? @map("last_error")
  lastAttemptedAt Int?    @map("last_attempted_at")
  metadataId      Int?    @map("metadata_id")
  displayName     String? @map("display_name")
  headerSnapshot  String? @map("header_snapshot") // JSON string: Record<string,string>

  imageMetadata ImageMetadata? @relation(fields: [metadataId], references: [id])

  @@index([taskId], name: "idx_task_failed_images_task")
  @@map("task_failed_images")
}

/// 运行配置表
model RunConfig {
  id                   String  @id
  name                 String
  description          String?
  pluginId             String  @map("plugin_id")
  url                  String
  outputDir            String? @map("output_dir")
  userConfig           String? @map("user_config") // JSON string
  httpHeaders          String? @map("http_headers") // JSON string: Record<string,string>
  createdAt            Int     @map("created_at")
  scheduleEnabled      Int     @default(0) @map("schedule_enabled") // 0/1
  scheduleSpec         String? @map("schedule_spec")
  schedulePlannedAt    Int?    @map("schedule_planned_at")
  scheduleLastRunAt    Int?    @map("schedule_last_run_at")

  @@map("run_configs")
}

/// 畅游记录表
model SurfRecord {
  id            String @id
  host          String @unique
  rootUrl       String @map("root_url")
  icon          Bytes?
  lastVisitAt   Int    @map("last_visit_at")
  downloadCount Int    @default(0) @map("download_count")
  deletedCount  Int    @default(0) @map("deleted_count")
  createdAt     Int    @map("created_at")
  name          String @default("")
  cookie        String @default("")

  @@index([host], name: "idx_surf_records_host")
  @@index([lastVisitAt(sort: Desc)], name: "idx_surf_records_last_visit")
  @@map("surf_records")
}

/// 插件源表（商店源）
model PluginSource {
  id        String @id
  name      String
  indexUrl  String @map("index_url")
  createdAt Int    @default(dbgenerated("strftime('%s','now')")) @map("created_at")

  cache PluginSourceCache?

  @@map("plugin_sources")
}

/// 插件源缓存表（存储插件源 index JSON 原始内容）
model PluginSourceCache {
  sourceId    String @id @map("source_id")
  jsonContent String @map("json_content")
  updatedAt   Int    @default(dbgenerated("strftime('%s','now')")) @map("updated_at")

  source PluginSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@map("plugin_source_cache")
}

/// 插件私有 JSON 缓存
model PluginData {
  pluginId  String @id @map("plugin_id")
  data      String // JSON string
  updatedAt Int    @default(dbgenerated("strftime('%s','now') * 1000")) @map("updated_at")

  @@map("plugin_data")
}

/// 任务日志表
model TaskLog {
  id      Int    @id @default(autoincrement())
  taskId  String @map("task_id")
  level   String
  content String
  time    Int

  @@index([taskId], name: "idx_task_logs_task_id")
  @@map("task_logs")
}
