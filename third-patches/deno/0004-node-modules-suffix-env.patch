+  let mut output = PathBuf::with_capacity(path.as_os_str().len());
+  for component in path.components() {
+    if component.as_os_str() == OsStr::new(&replaced) {
+      output.push("node_modules");
+    } else {
+      output.push(component.as_os_str());
+    }
+  }
+  Cow::Owned(output)
+}
+
+pub fn redirect_node_modules_path_buf(path: PathBuf) -> PathBuf {
+  match redirect_node_modules(&path) {
+    Cow::Borrowed(_) => path,
+    Cow::Owned(path) => path,
+  }
+}
