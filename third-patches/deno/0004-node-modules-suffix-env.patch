diff --git a/ext/napi/node_modules_suffix.rs b/ext/napi/node_modules_suffix.rs
new file mode 100644
index 0000000..c8b5b61
--- /dev/null
+++ b/ext/napi/node_modules_suffix.rs
@@ -0,0 +1,109 @@
+// Copyright 2018-2026 the Deno authors. MIT license.
+
+// kabegame patch(node_modules-suffix): see the twin copies in the deno CLI,
+// deno_fs, and deno_process.
+// DENO_NODE_MODULES_SUFFIX redirects every path component == "node_modules" to
+// "node_modules{suffix}" at the real-IO boundary (in-process bind mount for
+// per-glibc-environment native module isolation). Unset/empty => zero-cost no-op.
+
+use std::borrow::Cow;
+use std::ffi::OsStr;
+use std::path::Path;
+use std::path::PathBuf;
+use std::sync::OnceLock;
+
+fn suffix() -> Option<&'static str> {
+  static SUFFIX: OnceLock<Option<String>> = OnceLock::new();
+  SUFFIX
+    .get_or_init(|| {
+      std::env::var("DENO_NODE_MODULES_SUFFIX")
+        .ok()
+        .filter(|s| !s.is_empty())
+    })
+    .as_deref()
+}
+
+// kabegame patch(node_modules-suffix): mirrors deno_cache_dir::DenoDir so
+// package data inside Deno's own cache is never treated as installed modules.
+fn deno_cache_root() -> Option<&'static Path> {
+  static CACHE_ROOT: OnceLock<Option<PathBuf>> = OnceLock::new();
+  CACHE_ROOT
+    .get_or_init(|| {
+      let root = std::env::var_os("DENO_DIR")
+        .filter(|value| !value.is_empty())
+        .map(PathBuf::from)
+        .or_else(default_deno_cache_root)?;
+      if root.is_absolute() {
+        Some(root)
+      } else {
+        // Deno resolves a relative DENO_DIR against the initial cwd.
+        Some(
+          std::env::current_dir()
+            .map(|cwd| cwd.join(&root))
+            .unwrap_or(root),
+        )
+      }
+    })
+    .as_deref()
+}
+
+fn default_deno_cache_root() -> Option<PathBuf> {
+  #[cfg(windows)]
+  {
+    std::env::var_os("LOCALAPPDATA")
+      .filter(|value| !value.is_empty())
+      .map(PathBuf::from)
+      .map(|path| path.join("deno"))
+  }
+  #[cfg(target_os = "macos")]
+  {
+    std::env::var_os("HOME")
+      .filter(|value| !value.is_empty())
+      .map(PathBuf::from)
+      .map(|path| path.join("Library/Caches/deno"))
+  }
+  #[cfg(all(not(windows), not(target_os = "macos")))]
+  {
+    std::env::var_os("XDG_CACHE_HOME")
+      .filter(|value| !value.is_empty())
+      .map(PathBuf::from)
+      .map(|path| path.join("deno"))
+      .or_else(|| {
+        std::env::var_os("HOME")
+          .filter(|value| !value.is_empty())
+          .map(PathBuf::from)
+          .map(|path| path.join(".cache/deno"))
+      })
+  }
+}
+
+fn is_in_deno_cache(path: &Path) -> bool {
+  deno_cache_root().is_some_and(|root| path.starts_with(root))
+}
+
+pub fn redirect_node_modules(path: &Path) -> Cow<'_, Path> {
+  let Some(suffix) = suffix() else {
+    return Cow::Borrowed(path);
+  };
+  if is_in_deno_cache(path) {
+    return Cow::Borrowed(path);
+  }
+  if !path
+    .components()
+    .any(|component| component.as_os_str() == OsStr::new("node_modules"))
+  {
+    return Cow::Borrowed(path);
+  }
+
+  let replaced = format!("node_modules{suffix}");
+  let mut output =
+    PathBuf::with_capacity(path.as_os_str().len() + suffix.len());
+  for component in path.components() {
+    if component.as_os_str() == OsStr::new("node_modules") {
+      output.push(&replaced);
+    } else {
+      output.push(component.as_os_str());
+    }
+  }
+  Cow::Owned(output)
+}
