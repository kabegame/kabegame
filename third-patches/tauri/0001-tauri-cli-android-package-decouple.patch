+/// kabegame fork: Android 侧 Java 包(源码目录、生成 Kotlin 的 package、JNI 绑定)
+/// 由 `TAURI_ANDROID_PACKAGE` env 决定,与 identifier(applicationId/安装身份)解耦。
+/// 未设置或为空时回退 identifier,即 stock 行为。
+pub fn android_package(app: &App) -> String {
+  std::env::var("TAURI_ANDROID_PACKAGE")
+    .ok()
+    .filter(|p| !p.is_empty())
+    .unwrap_or_else(|| app.identifier().to_string())
+}
+
+/// kabegame fork: 与 cargo-mobile2 `App::android_identifier_escape_kotlin_keyword`
+/// 相同的转义逻辑,但作用于任意包名字符串(而非固定 identifier)。
+fn escape_kotlin_keywords(package: &str) -> String {
+  package
+    .split('.')
+    .map(|s| {
+      if cargo_mobile2::reserved_names::KOTLIN_ONLY_KEYWORDS.contains(&s) {
+        format!("`{s}`")
+      } else {
+        s.to_string()
+      }
+    })
+    .collect::<Vec<_>>()
+    .join(".")
+}
+
