--- a/crates/tauri-runtime/Cargo.toml
+++ b/crates/tauri-runtime/Cargo.toml
@@ -44,7 +44,9 @@ webview2-com = "0.38"
 
 [target."cfg(any(target_os = \"linux\", target_os = \"dragonfly\", target_os = \"freebsd\", target_os = \"openbsd\", target_os = \"netbsd\"))".dependencies]
 gtk = { version = "0.18", features = ["v3_24"] }
-webkit2gtk = { version = "=2.0", features = ["v2_40"] }
+# kabegame fork: webkit2gtk 变为可选,由 `webkit` feature 开启。
+# 非 webkit runtime(CEF)不启用该 feature,Linux 构建不再链接 webkit2gtk。
+webkit2gtk = { version = "=2.0", features = ["v2_40"], optional = true }
 
 [target."cfg(target_os = \"android\")".dependencies]
 jni = "0.21"
@@ -70,3 +72,5 @@ objc2-web-kit = { version = "0.3", default-features = false, features = [
 [features]
