diff --git a/crates/tauri-cli/src/interface/rust.rs b/crates/tauri-cli/src/interface/rust.rs
--- a/crates/tauri-cli/src/interface/rust.rs
+++ b/crates/tauri-cli/src/interface/rust.rs
@@ -130,6 +130,10 @@ pub struct RustupTarget {
 pub struct Rust {
   app_settings: Arc<RustAppSettings>,
   config_features: Vec<String>,
+  // kabegame fork(0009): 顶层 bins 配置与 tauri_dir,供 build_options 桌面分支
+  // 决定 cargo --bin 清单(回退 get_binaries 需要 tauri_dir)。
+  config_bins: Option<Vec<String>>,
+  tauri_dir: PathBuf,
   available_targets: Option<Vec<RustupTarget>>,
   main_binary_name: Option<String>,
 }
@@ -171,6 +175,8 @@ impl Rust {
     Ok(Self {
       app_settings: Arc::new(app_settings),
       config_features: config.build.features.clone().unwrap_or_default(),
+      config_bins: config.bins.clone(),
+      tauri_dir: tauri_dir.to_path_buf(),
       main_binary_name: config.main_binary_name.clone(),
       available_targets: None,
     })
@@ -488,7 +494,43 @@ impl Rust {
         args.push("--lib".into());
       }
     } else {
-      args.push("--bins".into());
+      // kabegame fork(0009-tauri-config-bins-compile-list): 桌面不再无差别
+      // `--bins` 编译 package 里全部 bin(会把示例类不出货的 bin 一起编进
+      // release)。改为:tauri.conf.json 顶层 `bins` 显式声明要编译的 bin
+      // (逐个翻译成 cargo 的 `--bin <name>`);未声明时回退到 get_binaries()
+      // 的打包清单(经 bundle-only-default-run 过滤,即仅 default-run 主 bin)。
+      // 带去重:args 里已有的 --bin 不重复追加;清单为空时回退上游 `--bins`。
+      // 仅桌面生效(mobile 走上方 --lib 分支)。
+      let has_bin_arg = |args: &[String], name: &str| {
+        args
+          .iter()
+          .any(|a| a.strip_prefix("--bin=").is_some_and(|v| v == name))
+          || args.windows(2).any(|w| w[0] == "--bin" && w[1] == name)
+      };
+      let bin_names: Vec<String> = match &self.config_bins {
+        Some(bins) => bins.clone(),
+        None => {
+          let options = Options {
+            features: features.clone(),
+            ..Default::default()
+          };
+          self
+            .app_settings
+            .get_binaries(&options, &self.tauri_dir)
+            .map(|bins| bins.iter().map(|bin| bin.name().to_string()).collect())
+            .unwrap_or_default()
+        }
+      };
+      if bin_names.is_empty() {
+        args.push("--bins".into());
+      } else {
+        for name in bin_names {
+          if !has_bin_arg(args, &name) {
+            args.push("--bin".into());
+            args.push(name);
+          }
+        }
+      }
     }
   }
 
