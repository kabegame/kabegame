diff --git a/crates/tauri-cli/src/interface/mod.rs b/crates/tauri-cli/src/interface/mod.rs
--- a/crates/tauri-cli/src/interface/mod.rs
+++ b/crates/tauri-cli/src/interface/mod.rs
@@ -66,6 +66,22 @@ pub trait AppSettings {
       main.set_name(main_binary_name.to_owned());
     }
 
+    // kabegame fork(0009-tauri-config-bins-compile-list): Windows 下把顶层
+    // `bins` 配置声明的辅助 bin 以非 main binary 挂进 bundle——NSIS 模板的
+    // binaries 段原生把它们装到 $INSTDIR 根(主 exe 旁)并在卸载时删除,
+    // 应用无需再经 resources + installer hook 搬运。macOS/Linux 的辅助 bin
+    // 布局各异(Contents/MacOS、/usr/lib/<app>),仍由 bundle files
+    // (macOS.files / deb files)显式声明,此处不扩展。
+    if target.contains("-windows-") {
+      if let Some(config_bins) = &config.bins {
+        for name in config_bins {
+          if !bins.iter().any(|b| b.name() == name) {
+            bins.push(tauri_bundler::BundleBinary::new(name.clone(), false));
+          }
+        }
+      }
+    }
+
     let mut settings_builder = SettingsBuilder::new()
