diff --git a/patch/patch.cfg b/patch/patch.cfg
index 340d5d8c830c8471efe45d7d780bad72059439b6..33e372fc3016ff6125663107b7ee81af1fe8d497 100644
--- a/patch/patch.cfg
+++ b/patch/patch.cfg
@@ -889,5 +889,11 @@ patches = [
     # Fix crash during shutdown in TaskManagerImpl::OnReceivedMemoryDump with
     # multi-threaded-message-loop.
     'name': 'chrome_browser_task_manager',
+  },
+  {
+    # kabegame: honor an explicit --browser-subprocess-path for every child
+    # process type (skips the macOS helper-app variant rewrite so a single
