diff --git a/sys/src/direct_link_loader_stubs.rs b/sys/src/direct_link_loader_stubs.rs
new file mode 100644
index 0000000..0fa0e78
--- /dev/null
+++ b/sys/src/direct_link_loader_stubs.rs
@@ -0,0 +1,14 @@
+/// Direct-link mode (kabegame vendored build): libcef is linked at build time
+/// via LC_LOAD_DYLIB, so the runtime loader entry points become no-ops that
+/// report success, satisfying references from `cef::library_loader`.
+#[no_mangle]
+pub extern "C" fn cef_load_library(
+    _library_path: *const std::os::raw::c_char,
+) -> std::os::raw::c_int {
+    1
+}
+
+#[no_mangle]
+pub extern "C" fn cef_unload_library() -> std::os::raw::c_int {
+    1
+}
