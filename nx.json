{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "maxCacheSize": "20MB",
  "targetDefaults": {
    "build-docs": {
      "cache": true,
      "inputs": ["frontendDocs"],
      "outputs": ["{workspaceRoot}/apps/docs/dist/**/*"]
    },
    "build-kabegame": {
      "cache": true,
      "inputs": ["frontendKabegame"],
      "outputs": ["{workspaceRoot}/dist-kabegame/**/*"]
    }
  },
  "namedInputs": {
    "default": ["{workspaceRoot}/*.pub.ts"],
    "frontendEnv": [
      { "env": "VITE_KABEGAME_MODE" },
      { "env": "KABEGAME_MODE" },
      { "env": "TAURI_ENV_PLATFORM" },
      { "env": "TAURI_PLATFORM" },
      { "env": "TAURI_DEBUG" }
    ],
    "frontendKabegame": [
      "{workspaceRoot}/apps/kabegame/**/*",
      "{workspaceRoot}/packages/*/src/**/*",
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/bun.lock",
      "frontendEnv",
      "default"
    ],
    "frontendDocs": [
      "{workspaceRoot}/apps/docs/**/*" 
    ],
    "sharedGlobals": []
  }
}
