WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Optional. Defaults are safe for draft creation.
WECHAT_AUTHOR=
WECHAT_CONTENT_SOURCE_URL=
WECHAT_NEED_OPEN_COMMENT=0
WECHAT_ONLY_FANS_CAN_COMMENT=0

# Inline article images are compressed below this size before upload.
# WeChat media/uploadimg is stricter than normal permanent materials.
WECHAT_MAX_INLINE_IMAGE_BYTES=950000
