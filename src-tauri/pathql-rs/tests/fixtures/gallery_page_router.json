{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_page_router",
    "properties": {
        "page_size": { "type": "number", "default": 1, "optional": false },
        "page_num":  { "type": "number", "default": 1, "optional": false }
    },
    "query": { "delegate": "./__provider" },
    "resolve": {
        "__provider": {
            "provider": "query_page_provider",
            "properties": {
                "page_size": "${properties.page_size}",
                "page_num":  "${properties.page_num}"
            }
        }
    }
}
