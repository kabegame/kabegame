{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_wallpaper_order_router",
    // 7c S5: programmatic GalleryWallpaperOrderRouter 迁 DSL。
    // 仅取被设过壁纸的图, 按 last_set_wallpaper_at ASC 排序 (最早被用作壁纸的排前)。
    "query": {
        "where": "images.last_set_wallpaper_at IS NOT NULL",
        "order": [{ "sql": "images.last_set_wallpaper_at", "order": "asc" }]
    },
    "resolve": {
        "desc|x[1-9][0-9]*x|[1-9][0-9]*": {
            "delegate": {
                "provider": "kabegame.gallery_desc_pagination_page_comb"
            },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        }
    }
}
