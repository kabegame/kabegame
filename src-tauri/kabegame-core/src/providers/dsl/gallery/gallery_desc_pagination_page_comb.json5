{
  "$schema": "../schema.json5",
  "namespace": "kabegame",
  "name": "gallery_desc_pagination_page_comb",
  "resolve": {
    "desc": { "provider": "gallery_desc_router" },
    "x([1-9][0-9]*)x": {
      "provider": "gallery_paginate_router",
      "properties": { "page_size": "${capture[1]}" }
    },
    "([1-9][0-9]*)": {
      "provider": "query_page_provider",
      "properties": {
        "page_size": 100,
        "page_num": "${capture[1]}"
      }
    }
  }
}
