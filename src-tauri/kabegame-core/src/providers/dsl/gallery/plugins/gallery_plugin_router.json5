{
    "$schema": "../../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_plugin_router",
    "properties": {
        "plugin_id": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "delegate": {
            "provider": "plugin_provider",
            "properties": { "plugin_id": "${properties.plugin_id}" }
        }
    },
    "resolve": {
        "extend": {
            "provider": "plugin_entry_provider",
            "properties": { "plugin_id": "${properties.plugin_id}" }
        },
        "desc|x[1-9][0-9]*x|[1-9][0-9]*": {
            "delegate": {
                "provider": "kabegame.gallery_desc_pagination_page_comb"
            },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        }
    }
}
