{
    "$schema": "../../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_by_id_provider",
    "properties": {
        "image_id": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "where": "images.id = ${properties.image_id}",
        "limit": 1
    }
}
