{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "vd_month_ja_provider",
    "properties": {
        "year_month": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "delegate": {
            "provider": "month_provider",
            "properties": {
                "year_month": "${properties.year_month}"
            }
        }
    },
    "list": {
        "${root.name}日": {
            "delegate": {
                "provider": "month_provider",
                "properties": {
                    "year_month": "${properties.year_month}"
                }
            },
            "child_var": "root",
            "provider": "vd_day_ja_provider",
            "properties": {
                "ymd": "${properties.year_month}-${root.name}"
            },
            "meta": {
                "day": "${root.name}",
                "label": "${root.name}日"
            }
        },
        "${page.name}": {
            "child_var": "page",
            "delegate": {
                "provider": "page_size_provider",
                "properties": { "page_size": 100 }
            },
            "provider": "query_page_provider",
            "properties": {
                "page_size": 100,
                "page_num": "${page.meta.page_num}"
            },
            "meta": "${page.meta}"
        }
    }
}
