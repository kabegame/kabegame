{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "vd_plugins_provider",
    "list": {
        "${plugin.meta.display}": {
            "delegate": {
                "provider": "plugins_provider"
            },
            "child_var": "plugin",
            "provider": "gallery_plugin_router",
            "properties": { "plugin_id": "${plugin.name}" },
            "meta": "${plugin.meta.plugin}"
        }
    },
    "resolve": {
        "(?:.* - )?([a-z][a-z0-9_-]*)": {
            "provider": "gallery_plugin_router",
            "properties": { "plugin_id": "${capture[1]}" }
        }
    }
}
