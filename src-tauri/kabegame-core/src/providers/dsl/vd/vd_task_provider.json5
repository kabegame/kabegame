{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "vd_task_provider",
    "properties": {
        "task_id": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "delegate": {
            "provider": "task_provider",
            "properties": {
                "task_id": "${properties.task_id}"
            }
        }
    },
    "list": {
        "${page.name}": {
            "child_var": "page",
            "delegate": {
                "provider": "page_size_provider",
                "properties": { "page_size": 100 }
            },
            "provider": "query_page_provider",
            "properties": {
                "page_size": 100,
                "page_num": "${page.meta.page_num}"
            },
            "meta": "${page.meta}"
        }
    }
}
