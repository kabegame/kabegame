{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "vd_all_provider",
    // 固定 DEFAULT_PAGE_SIZE=100, 直接列页号; 不暴露 desc/xNNNx。
    "list": {
        "${out.name}": {
            "child_var": "out",
            "delegate": {
                "provider": "paginate100_provider",
            },
            "provider": "${out.provider}",
            "meta": "${out.meta}"
        }
    }
}
