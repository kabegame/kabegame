{
    "namespace": "kabegame",
    "name": "gallery_name_router",
    // 按 display_name 的语种桶浏览。桶顺序由当前 UI locale 决定；路径段保持稳定英文。
    "list": {
        "${out.bucket}": {
            "sql": "SELECT bucket FROM (SELECT name_language_bucket(COALESCE(sub.display_name, '')) AS bucket, COUNT(*) AS cnt FROM (${composed}) AS sub GROUP BY name_language_bucket(COALESCE(sub.display_name, ''))) WHERE cnt > 0 ORDER BY name_language_rank(bucket)",
            "data_var": "out",
            "provider": "name_language_bucket_provider",
            "properties": {
                "bucket": "${out.bucket}"
            },
            "meta": {
                "bucket": "${out.bucket}"
            }
        }
    },
    "resolve": {
        "english|chinese|japanese|korean|other": {
            "provider": "name_language_bucket_provider",
            "properties": {
                "bucket": "${capture[0]}"
            }
        }
    }
}
