{
    "namespace": "kabegame",
    "name": "gallery_sort_by_time_provider",
    "query": {
        "order": [{ "sql": "images.crawled_at", "order": "asc", "clear": "all" }]
    },
    "resolve": {
        "desc|x[1-9][0-9]*x|[1-9][0-9]*": {
            "delegate": {
                "provider": "kabegame.gallery_desc_pagination_page_comb"
            },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        }
    }
}
