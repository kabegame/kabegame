{
    "namespace": "kabegame",
    "name": "gallery_album_order_provider",
    "query": {
        "order": [{ "sql": "COALESCE(ai.\"order\", ai.rowid)", "order": "asc", "prepend": true, "clear": "all" }]
    },
    "resolve": {
        "desc|x[1-9][0-9]*x|[1-9][0-9]*": {
            "delegate": {
                "provider": "kabegame.gallery_desc_pagination_page_comb"
            },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        },
        "l([0-9]+)l": {
            "provider": "limit_leaf_provider",
            "properties": { "limit": "${capture[1]}" }
        }
    }
}
