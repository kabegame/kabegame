{
    "namespace": "kabegame",
    "name": "gallery_album_bigger_order_filter",
    "properties": {
        "order": { "type": "string", "default": "0", "optional": false }
    },
    "query": {
        // album 顺序模式: WHERE ai."order" > N, ORDER BY ai."order" ASC
        "where": "ai.\"order\" > ${properties.order}",
        "order": [{ "sql": "ai.\"order\"", "order": "asc", "prepend": true, "clear": "all" }]
    },
    "resolve": {
        "desc|x[1-9][0-9]*x|[1-9][0-9]*": {
            "delegate": {
                "provider": "kabegame.gallery_desc_pagination_page_comb"
            },
            "child_var": "root",
            "provider": "${root.provider}",
            "meta": "${root.meta}"
        },
        "l([0-9]+)l": {
            "provider": "limit_leaf_provider",
            "properties": {
                "limit": "${capture[1]}"
            }
        }
    }
}
