{
    "namespace": "kabegame",
    "name": "gallery_task_provider",
    "properties": {
        "task_id": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "delegate": {
            "provider": "task_provider",
            "properties": {
                "task_id": "${properties.task_id}"
            }
        }
    },
    "resolve": {
        "desc|x[1-9][0-9]*x|[1-9][0-9]*": {
            "delegate": {
                "provider": "kabegame.gallery_desc_pagination_page_comb"
            },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        }
    }
}
