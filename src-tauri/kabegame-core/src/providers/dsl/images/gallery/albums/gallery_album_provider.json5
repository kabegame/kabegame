{
    "namespace": "kabegame",
    "name": "gallery_album_provider",
    "properties": {
        "album_id": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "where": "ai.album_id = ${properties.album_id}"
    },
    "list": {
        "${out.id}": {
            "sql": "SELECT id, name, created_at, parent_id, type, sync_folder, folder_status FROM albums WHERE parent_id = ${properties.album_id} ORDER BY name_language_rank(name_language_bucket(COALESCE(name, ''))) ASC, name COLLATE NOCASE ASC, created_at ASC",
            "data_var": "out",
            "provider": "gallery_album_provider",
            "properties": {
                "album_id": "${out.id}"
            },
            "meta": {
                "kind": "album",
                "data": {
                    "id": "${out.id}",
                    "name": "${out.name}",
                    "createdAt": "${out.created_at}",
                    "parentId": "${out.parent_id}",
                    "type": "${out.type}",
                    "syncFolder": "${out.sync_folder}",
                    "folderStatus": "${out.folder_status}"
                }
            }
        }
    },
    "resolve": {
        "image-only": {
            "provider": "gallery_album_media_type_provider",
            "properties": { "kind": "image" }
        },
        "video-only": {
            "provider": "gallery_album_media_type_provider",
            "properties": { "kind": "video" }
        },
        "bigger_order": { "provider": "gallery_album_bigger_order_router" },
        "id_([^/]+)": {
            "provider": "gallery_by_id_provider",
            "properties": { "image_id": "${capture[1]}" }
        },
        "filter_comb": {
            "provider": "gallery_filter_comb"
        },
        "all|wallpaper-order|no-album|name|names|plugin|plugins|media-type|date|dates|sort|size|aspect|dimension|dimensions": {
            "delegate": { "provider": "gallery_route" },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        },
        "desc|x[1-9][0-9]*x|[1-9][0-9]*": {
            "delegate": {
                "provider": "kabegame.gallery_desc_pagination_page_comb"
            },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        },
        "[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}": {
            "provider": "gallery_album_provider",
            "properties": { "album_id": "${capture[0]}" }
        }
    }
}
