{
    "namespace": "kabegame",
    "name": "gallery_surf_provider",
    "properties": {
        "host": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        // host 与 record_id 一一对应 (Storage::add_surf_record 对 host 幂等)。
        "delegate": {
            "provider": "surf_provider",
            "properties": {
                "host": "${properties.host}"
            }
        }
    },
    "resolve": {
        "desc|x[1-9][0-9]*x|[1-9][0-9]*": {
            "delegate": {
                "provider": "kabegame.gallery_desc_pagination_page_comb"
            },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        }
    }
}
