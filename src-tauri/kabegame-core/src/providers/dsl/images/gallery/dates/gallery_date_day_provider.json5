{
    "namespace": "kabegame",
    "name": "gallery_date_day_provider",
    "properties": {
        "ymd": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "delegate": {
            "provider": "day_provider",
            "properties": {
                "ymd": "${properties.ymd}"
            }
        }    
    },
    "resolve": {
        "filter_comb": {
            "provider": "gallery_filter_comb"
        },
        "desc|x[1-9][0-9]*x|[1-9][0-9]*": {
            "delegate": {
                "provider": "kabegame.gallery_desc_pagination_page_comb"
            },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        },
    }
}
