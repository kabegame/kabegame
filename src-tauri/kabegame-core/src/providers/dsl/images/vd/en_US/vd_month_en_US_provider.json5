{
    "namespace": "kabegame",
    "name": "vd_month_en_US_provider",
    "properties": {
        "year_month": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "delegate": {
            "provider": "month_provider",
            "properties": {
                "year_month": "${properties.year_month}"
            }
        }
    },
    "list": {
        "All Month": {
            "provider": "paginate100_provider",
            "meta": { "label": "All Month" }
        },
        "${global:vd_en_US_day|root.name}": {
            "delegate": {
                "provider": "month_provider",
                "properties": {
                    "year_month": "${properties.year_month}"
                }
            },
            "child_var": "root",
            "provider": "vd_day_en_US_provider",
            "properties": {
                "ymd": "${properties.year_month}-${root.name}"
            },
            "meta": {
                "day": "${root.name}",
                "label": "${global:vd_en_US_day|root.name}"
            }
        }
    }
}
