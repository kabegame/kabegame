{
    "namespace": "kabegame",
    "name": "images_root_provider",
    "query": {
        "fields": ["images.*"],
    },
    "list": {
        "gallery": { "provider": "gallery_route" },
        "vd": { "provider": "vd_root_router" }
    },
    "resolve": {
        "x([1-9][0-9]*)x": {
            "delegate": { "provider": "image_basic_provider" },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        },
        "id_([^/]+)": {
            "delegate": { "provider": "image_basic_provider" },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        }
    }
}
