{
    "namespace": "kabegame",
    "name": "albums_by_type_provider",
    "properties": {
        "type": { "type": "string", "default": "normal", "optional": false }
    },
    "query": {
        "where": "albums.type = ${properties.type}",
        "order": [{ "sql": "albums.created_at", "order": "asc" }]
    }
}
