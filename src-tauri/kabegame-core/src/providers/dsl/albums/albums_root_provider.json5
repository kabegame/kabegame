{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "albums_root_provider",
    "query": {
        "from": "albums",
        "fields": [
            { "sql": "albums.id", "as": "id" },
            { "sql": "albums.name", "as": "name" },
            { "sql": "albums.created_at", "as": "created_at" },
            { "sql": "albums.parent_id", "as": "parent_id" }
        ],
        "order": [{ "sql": "albums.created_at", "order": "desc" }]
    },
    "list": {
        "all": { "provider": "albums_all_provider" }
    }
}
