{
    "namespace": "kabegame",
    "name": "fail_images_task_provider",
    "properties": {
        "task_id": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "where": "task_failed_images.task_id = ${properties.task_id}",
        "order": [{ "sql": "task_failed_images.id", "order": "desc" }]
    }
}
