{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "dates_provider",
    // 7c S7-b: programmatic GalleryDatesRouter 迁 DSL。年→月→日 三层结构,
    // 本层是年; apply_query 给上游加 crawled_at ASC 排序基线 (与 programmatic 同)。
    "query": {
        "order": [{ "sql": "images.crawled_at", "order": "asc" }]
    },
    "list": {
        // 从 composed 抽 distinct 年 (DESC, 最近的先)。${composed} 已带 gallery_route fields/joins。
        "${out.year}": {
            "sql": "SELECT DISTINCT strftime('%Y', crawled_at_seconds(sub.crawled_at), 'unixepoch') AS year FROM (${composed}) AS sub WHERE strftime('%Y', crawled_at_seconds(sub.crawled_at), 'unixepoch') IS NOT NULL ORDER BY year DESC",
            "data_var": "out",
            "meta": "${out}"
        }
    },
}
