{
    "namespace": "kabegame",
    "name": "aspect_bucket_provider",
    // Shared aspect-ratio bucket filter. Boundaries are mutually exclusive:
    // portrait [9:16, 3:4), square [3:4, 4:3], landscape (4:3, 16:9],
    // widescreen (16:9, 21:9], other = too narrow, too wide, or invalid dimensions.
    "properties": {
        "bucket": { "type": "string", "default": "other", "optional": false }
    },
    "query": {
        "where": "CASE WHEN images.width IS NULL OR images.height IS NULL OR images.width <= 0 OR images.height <= 0 THEN 'other' WHEN images.width * 16 >= images.height * 9 AND images.width * 4 < images.height * 3 THEN 'portrait' WHEN images.width * 4 >= images.height * 3 AND images.width * 3 <= images.height * 4 THEN 'square' WHEN images.width * 3 > images.height * 4 AND images.width * 9 <= images.height * 16 THEN 'landscape' WHEN images.width * 9 > images.height * 16 AND images.width * 3 <= images.height * 7 THEN 'widescreen' ELSE 'other' END = ${properties.bucket}"
    }
}
