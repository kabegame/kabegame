{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "paginate_provider",
    "properties": {
        "page_size": { "type": "number", "default": 100, "min": 1, "optional": true }
    },
    "list": {
        // 100 分页，输出 1..last_page
        "${out.name}": {
            "delegate": {
                "provider": "page_size_provider",
                "properties": {
                    "page_size": "${properties.page_size}",
                }
            },
            "child_var": "out",
            "provider": "query_page_provider",
            "properties": {
                "page_size": "${properties.page_size}",
                "page_num": "${out.name}"
            },
            "meta": "${out.meta}"
            // 无 provider 字段: 子节点不挂 provider, 仅作路径段存在(被上层 paginate_router 通过 meta 字段引用)
        }
    }
}
