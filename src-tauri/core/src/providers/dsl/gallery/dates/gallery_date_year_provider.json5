{
    "$schema": "../../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_date_year_provider",
    "properties": {
        "year": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "where": "strftime('%Y', crawled_at_seconds(images.crawled_at), 'unixepoch') = ${properties.year}"
    },
    // list: desc 静态 + 动态月份 + 默认分页静态 (与 programmatic 同; 用户在年下既可看月也可直接翻页)
    "list": {
        "desc":   { "provider": "sort_provider" },
        "${out.mm}m": {
            "sql": "SELECT DISTINCT substr(strftime('%Y-%m', crawled_at_seconds(images.crawled_at), 'unixepoch'), 6, 2) AS mm FROM (${composed}) AS sub WHERE strftime('%Y-%m', crawled_at_seconds(images.crawled_at), 'unixepoch') IS NOT NULL ORDER BY mm DESC",
            "data_var": "out",
            "provider": "gallery_date_month_provider",
            "properties": {
                "year_month": "${properties.year}-${out.mm}"
            }
        },
        "x100x":  { "provider": "gallery_paginate_router", "properties": { "page_size": 100 } },
        "x500x":  { "provider": "gallery_paginate_router", "properties": { "page_size": 500 } },
        "x1000x": { "provider": "gallery_paginate_router", "properties": { "page_size": 1000 } }
    },
    "resolve": {
        "([0-9]{2})m": {
            "provider": "gallery_date_month_provider",
            "properties": {
                "year_month": "${properties.year}-${capture[1]}"
            }
        },
        "x([1-9][0-9]*)x": {
            "provider": "gallery_paginate_router",
            "properties": { "page_size": "${capture[1]}" }
        },
        "([1-9][0-9]*)": {
            "provider": "query_page_provider",
            "properties": {
                "page_size": 100,
                "page_num": "${capture[1]}"
            }
        }
    }
}
