{
    "$schema": "../../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_plugin_provider",
    "properties": {
        "plugin_id": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "where": "images.plugin_id = ${properties.plugin_id}"
    },
    // 默认分页 (与 default_pagination_children 等价): desc + x100x/x500x/x1000x
    "list": {
        "desc":   { "provider": "sort_router" },
        "${page.name}": {
            "child_var": "page",
            "delegate": {
                "provider": "page_size_provider",
                "properties": { "page_size": 100 }
            },
            "provider": "gallery_page_router",
            "properties": {
                "page_size": 100,
                "page_num": "${page.meta.page_num}"
            }
        },
    },
    // 默认分页 resolve: xNNNx + 裸数字 (与 default_pagination_resolve 等价)
    "resolve": {
        "x([1-9][0-9]*)x": {
            "provider": "gallery_paginate_router",
            "properties": { "page_size": "${capture[1]}" }
        },
        "([1-9][0-9]*)": {
            "provider": "gallery_page_router",
            "properties": {
                "page_size": 100,
                "page_num": "${capture[1]}"
            }
        }
    }
}
