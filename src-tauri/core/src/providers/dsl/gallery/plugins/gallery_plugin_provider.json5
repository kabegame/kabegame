{
    "$schema": "../../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_plugin_router",
    "properties": {
        "plugin_id": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "delegate": {
            "provider": "plugin_provider",
            "properties": { "plugin_id": "${properties.plugin_id}" }
        }
    },
    "list": {
        "${page.name}": {
            "child_var": "page",
            "delegate": {
                "provider": "page_size_provider",
                "properties": { "page_size": 100 }
            },
            "provider": "gallery_page_router",
            "properties": {
                "page_size": 100,
                "page_num": "${page.meta.page_num}"
            }
        }
    },
    "resolve": {
        "desc": { "provider": "sort_router" },
        "extend": {
            "provider": "plugin_entry_provider",
            "properties": { "plugin_id": "${properties.plugin_id}" }
        },
        "x([1-9][0-9]*)x": {
            "provider": "gallery_paginate_router",
            "properties": { "page_size": "${capture[1]}" }
        },
        "([1-9][0-9]*)": {
            "provider": "gallery_page_router",
            "properties": {
                "page_size": 100,
                "page_num": "${capture[1]}"
            }
        }
    }
}
