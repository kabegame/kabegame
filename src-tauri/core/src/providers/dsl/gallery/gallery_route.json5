{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_route",
    "properties": {
        // todo: 改成全局变量，可通过 global.xxx 访问
        "fav_ai_id": {
            "type": "string",
            "default": "00000000-0000-0000-0000-000000000001",
            "optional": true
        },
        "hidden_ai_id": {
            "type": "string",
            "default": "00000000-0000-0000-0000-000000000000",
            "optional": true
        }
    },
    "query": {
        "fields": [
            {
                "sql": "CAST(images.id AS TEXT)",
                "as": "id"
            }, 
            { "sql": "images.url" }, 
            { "sql": "images.local_path" }, 
            { "sql": "images.plugin_id" },
            { "sql": "images.task_id" },
            { "sql": "images.crawled_at" },
            { "sql": "images.metadata_id" },
            { 
                "sql": "COALESCE(NULLIF(images.thumbnail_path, ''), images.local_path)",
                "as": "thumbnail_path"
            },
            { "sql": "images.hash" },
            { 
                "sql": "CASE WHEN fav_ai.image_id IS NOT NULL THEN 1 ELSE 0 END",
                "as": "is_favorite"
            },
            {
                "sql": "CASE WHEN hid_ai.image_id IS NOT NULL THEN 1 ELSE 0 END",
                "as": "is_hidden"
            },
            { "sql": "images.width" },
            { "sql": "images.height" },
            { "sql": "images.display_name" },
            {
                "sql": "COALESCE(images.type, 'image')",
                "as": "media_type"
            },
            { "sql": "images.last_set_wallpaper_at" },
            { "sql": "images.size" }
        ],
        "order": [{"images.crawled_at": "asc"}],
        // 因为total是从这里来的，所以不组织list images，但会卡死
        "join": [{
            "kind": "LEFT",
            "table": "album_images",
            "as": "fav_ai",
            "on": "images.id = fav_ai.image_id and fav_ai.album_id = ${properties.fav_ai_id}",
        }, {
            "kind": "LEFT",  
            "table": "album_images",
            "as": "hid_ai",
            "on": "images.id = hid_ai.image_id and hid_ai.album_id = ${properties.hidden_ai_id}",
        }]
    },
    "list": {
        // 注: list key 是前端 URL 段; 同时接受单数 / 复数两种写法 (frontend 各处历史不一致,
        // galleryPath.ts 用 plugin/date, albumPath.ts 用 album, 等等)。provider 注册名是
        // 复数 (kabegame.gallery_*_router) — runtime 内部, 前端不见。
        "all": {
            "provider": "gallery_all_router"
        },
        "wallpaper-order": {
            "provider": "gallery_wallpaper_order_router"
        },
        "plugin": {
            "provider": "gallery_plugins_router"
        },
        "plugins": {
            "provider": "gallery_plugins_router"
        },
        "task": {
            "provider": "gallery_tasks_router"
        },
        "tasks": {
            "provider": "gallery_tasks_router"
        },
        "surf": {
            "provider": "gallery_surfs_router"
        },
        "surfs": {
            "provider": "gallery_surfs_router"
        },
        "media-type": {
            "provider": "gallery_media_type_router"
        },
        "date": {
            "provider": "gallery_dates_router"
        },
        "dates": {
            "provider": "gallery_dates_router"
        },
        "album": {
            "provider": "gallery_albums_router"
        },
        // 日期范围(连续区间, 任意起止), 与 dates(年/月/日聚合) 互补
        "date-range": {
            "provider": "gallery_date_range_router"
        },
        "albums": {
            "provider": "gallery_albums_router"
        },
        "hide": {
            "provider": "gallery_hide_router"
        },
        "search": {
            "provider": "gallery_search_router"
        }
    }
}