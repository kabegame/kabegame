{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_wallpaper_order_router",
    // 7c S5: programmatic GalleryWallpaperOrderRouter 迁 DSL。
    // 仅取被设过壁纸的图, 按 last_set_wallpaper_at ASC 排序 (最早被用作壁纸的排前)。
    "query": {
        "where": "images.last_set_wallpaper_at IS NOT NULL",
        "order": [{ "images.last_set_wallpaper_at": "asc" }]
    },
    "list": {
        "desc":   { "provider": "sort_router" },
        "${page.name}": {
            "child_var": "page",
            "delegate": {
                "provider": "page_size_provider",
                "properties": { "page_size": 100 }
            },
            "provider": "gallery_page_router",
            "properties": {
                "page_size": 100,
                "page_num": "${page.meta.page_num}"
            }
        },
        "x100x":  { "provider": "gallery_paginate_router", "properties": { "page_size": 100 } },
        "x500x":  { "provider": "gallery_paginate_router", "properties": { "page_size": 500 } },
        "x1000x": { "provider": "gallery_paginate_router", "properties": { "page_size": 1000 } }
    },
    "resolve": {
        "x([1-9][0-9]*)x": {
            "provider": "gallery_paginate_router",
            "properties": { "page_size": "${capture[1]}" }
        },
        "([1-9][0-9]*)": {
            "provider": "gallery_page_router",
            "properties": {
                "page_size": 100,
                "page_num": "${capture[1]}"
            }
        }
    }
}
