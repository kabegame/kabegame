{
    "$schema": "../../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_media_type_provider",
    "properties": {
        "kind": { "type": "string", "default": "image", "optional": false }
    },
    // WHERE 按 kind 分支: image = 非 video 媒体, video = video / video/* 媒体。
    // 用 CASE 单条 SQL 同时表达两分支, kind 作为 bind 参数。
    "query": {
        "where": "CASE ${properties.kind} WHEN 'video' THEN (LOWER(COALESCE(images.type, '')) = 'video' OR LOWER(COALESCE(images.type, '')) LIKE 'video/%') ELSE NOT (LOWER(COALESCE(images.type, '')) = 'video' OR LOWER(COALESCE(images.type, '')) LIKE 'video/%') END"
    },
    "list": {
        "desc":   { "provider": "sort_provider" },
        "x100x":  { "provider": "gallery_paginate_router", "properties": { "page_size": 100 } },
        "x500x":  { "provider": "gallery_paginate_router", "properties": { "page_size": 500 } },
        "x1000x": { "provider": "gallery_paginate_router", "properties": { "page_size": 1000 } }
    },
    "resolve": {
        "x([1-9][0-9]*)x": {
            "provider": "gallery_paginate_router",
            "properties": { "page_size": "${capture[1]}" }
        },
        "([1-9][0-9]*)": {
            "provider": "query_page_provider",
            "properties": {
                "page_size": 100,
                "page_num": "${capture[1]}"
            }
        }
    }
}
