{
    "$schema": "../../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_media_type_router",
    // 7c S5: 静态二选一: image / video。
    "list": {
        "image": {
            "provider": "gallery_media_type_provider",
            "properties": { "kind": "image" }
        },
        "video": {
            "provider": "gallery_media_type_provider",
            "properties": { "kind": "video" }
        }
    }
}
