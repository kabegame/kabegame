{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "gallery_hide_router",
    "query": {
        "where": "hid_ai.image_id IS NULL"
    },
    "list": {
        "${root.name}": {
            "child_var": "root",
            "delegate": {
                "provider": "gallery_route"
            },
            "provider": "${root.provider}",
            "meta": "${root.meta}"
        }
    },
    "resolve": {
        ".*": {
            "delegate": { "provider": "gallery_route" },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        }
    }
}
