{
  "$schema": "../schema.json5",
  "namespace": "kabegame",
  "name": "vd_ja_plugin_router",
  "properties": { "plugin_id": { "type": "string", "default": "", "optional": false } },
  "query": {
    "delegate": {
      "provider": "plugin_provider",
      "properties": { "plugin_id": "${properties.plugin_id}" },
    },
  },
  "list": {
    "拡張": { "provider": "plugins.${properties.plugin_id}.entry_provider" },
    "すべて": { "provider": "vd_all_provider" },
  },
  "resolve": {
    "拡張": { "provider": "plugins.${properties.plugin_id}.entry_provider" },
    "すべて": { "provider": "vd_all_provider" },
  },
}
