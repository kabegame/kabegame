{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "vd_tasks_provider",
    "list": {
        "${root.name}": {
            "child_var": "root",
            "delegate": { "provider": "gallery_tasks_router" }
        }
    },
    "resolve": {
        ".*": { "delegate": { "provider": "gallery_tasks_router" } }
    }
}
