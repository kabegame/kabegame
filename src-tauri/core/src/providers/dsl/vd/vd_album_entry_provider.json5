{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "vd_album_entry_provider",
    "properties": {
        "album_id": { "type": "string", "default": "", "optional": false }
    },
    "query": {
        "where": "ai.album_id = ${properties.album_id}"
    },
    // list = subAlbums 入口 (SQL 检测有子) + 默认分页静态。
    // SQL 仅在子画册非空时输出一行 → key 渲染为本地化的 "subAlbums" 显示名。
    "list": {
        "${out.gate_name}": {
            "sql": "SELECT vd_display_name('subAlbums') AS gate_name FROM albums WHERE parent_id = ${properties.album_id} LIMIT 1",
            "data_var": "out",
            "provider": "vd_sub_album_gate_provider",
            "properties": { "parent_album_id": "${properties.album_id}" }
        },
        "desc":   { "provider": "sort_provider" },
        "x100x":  { "provider": "gallery_paginate_router", "properties": { "page_size": 100 } },
        "x500x":  { "provider": "gallery_paginate_router", "properties": { "page_size": 500 } },
        "x1000x": { "provider": "gallery_paginate_router", "properties": { "page_size": 1000 } }
    },
    "resolve": {
        "x([1-9][0-9]*)x": {
            "provider": "gallery_paginate_router",
            "properties": { "page_size": "${capture[1]}" }
        },
        "([1-9][0-9]*)": {
            "provider": "query_page_provider",
            "properties": {
                "page_size": 100,
                "page_num": "${capture[1]}"
            }
        }
    }
}
