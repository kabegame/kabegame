{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "vd_zh_CN_root_router",
    // 中文 (简体) 路径段 -> 业务 provider
    // 翻译文本作路径段; 业务 provider 与 locale 解耦
    "list": {
        "画册":     { "provider": "vd_albums_provider" },
        "按插件":   { "provider": "vd_zh_CN_plugins_provider" },
        "按任务":   { "provider": "vd_tasks_provider" },
        "按畅游":   { "provider": "vd_surfs_provider" },
        "按媒体":   { "provider": "vd_media_type_provider" },
        "按时间":   { "provider": "vd_dates_provider" },
        "全部":     { "provider": "vd_all_provider" }
    }
}
