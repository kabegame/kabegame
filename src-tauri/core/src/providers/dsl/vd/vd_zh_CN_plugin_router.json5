{
  "$schema": "../schema.json5",
  "namespace": "kabegame",
  "name": "vd_zh_CN_plugin_router",
  "properties": {
    "plugin_id": {
      "type": "string",
      "default": "",
      "optional": false
    }
  },
  "query": {
    "delegate": {
      "provider": "plugin_provider",
      "properties": {
        "plugin_id": "${properties.plugin_id}"
      }
    }
  },
  "list": {
    "扩展": {
      "provider": "plugins.${properties.plugin_id}.entry_provider"
    },
    "全部": {
      "provider": "vd_all_provider"
    }
  },
  "resolve": {
    "扩展": {
      "provider": "plugins.${properties.plugin_id}.entry_provider"
    },
    "全部": {
      "provider": "vd_all_provider"
    }
  }
}