{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "vd_surfs_provider",
    "list": {
        "${root.name}": {
            "child_var": "root",
            "delegate": { "provider": "gallery_surfs_router" },
            "provider": "${root.provider}",
            "meta": "${root.meta}"
        }
    },
    "resolve": {
        ".*": {
            "delegate": { "provider": "gallery_surfs_router" },
            "child_var": "child",
            "provider": "${child.provider}",
            "meta": "${child.meta}"
        }
    }
}
