{
    "$schema": "../schema.json5",
    "namespace": "kabegame",
    "name": "images_metadata_provider",
    "query": {
        "join": [{
            "kind": "LEFT",
            "table": "image_metadata",
            "as": "im",
            "on": "images.metadata_id = im.id",
            "in_need": true
        }],
        "fields": [
            {
                "sql": "im.data",
                "as": "metadata_json",
                "in_need": true
            },
            {
                "sql": "images.metadata",
                "as": "legacy_metadata_json",
                "in_need": true
            }
        ],
        "limit": 1
    }
}
