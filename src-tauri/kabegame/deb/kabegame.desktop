# 用来声明打开app的方法
[Desktop Entry]
Version=1.0
Type=Application
Name={{name}}
Name[en]=Kabegame
Comment=二次元壁纸管理器
Comment[en]=Anime Wallpaper Manager
Exec={{exec}}
Icon={{icon}}
Terminal=false
Categories=Graphics;Viewer;Utility;
StartupNotify=true
# 与 CEF 窗口的 WM_CLASS(可执行文件名)对应,任务栏据此把窗口和启动反馈归到本条目
StartupWMClass={{exec}}
Keywords=wallpaper;anime;image;gallery;
