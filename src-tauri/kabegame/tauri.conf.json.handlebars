{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kabegame",
  "version": "4.4.0",
  {{#unless isAndroid}}
  {{!-- fork 顶层 bins(patch 0009):桌面 tauri build 只编译这里列出的 bin
       (逐个 --bin 传给 cargo,不再 --bins 全量编译,examples 不进 release);
       Windows 下辅助 bin 还会由 NSIS 原生装到安装根(主 exe 旁)并随卸载删除,
       无需 resources/bin + installer hook 搬运。macOS/Linux 的 helper 仍走下方
       macOS.files / deb files 显式映射。 --}}
  "bins": ["kabegame", "kabegame-cef-helper"],
  {{/unless}}
  "identifier": {{#if isAndroid}}{{#if isDev}}"app.kabegame.dev"{{else}}"app.kabegame"{{/if}}{{else}}"Kabegame"{{/if}},
  "build": {
    "beforeDevCommand": "deno task dev:frontend",
    "devUrl": "http://{{devServerHost}}:1420"{{#unless isDev}},
    "frontendDist": "../../dist-kabegame"{{/unless}}
  },
  "app": {
    {{#if isMacOS}}
    "macOSPrivateApi": false,
    {{/if}}
    {{#if isAndroid}}
    {{!-- 注意：安卓必须有 windows 配置，否则白屏 --}}
    "windows": [
      {
        "label": "main",
        "visible": true,
        "fullscreen": false,
        "resizable": true,
        "title": "Kabegame",
        "devtools": {{isDev}}
      }
    ],
    {{else}}
    "windows": [],
    {{/if}}
    "security": {
      "capabilities": ["main-capability"{{#if isAndroid}}, "android-capability"{{else}}, "crawler-capability", "surf-capability", "surf-navbar-capability"{{/if}}],
      "csp": "default-src 'self' ipc: cef-ipc: http://ipc.localhost{{#if isAndroid}} http://{{devServerHost}}:1420 http://10.0.2.2:1420 http://localhost:1420{{/if}}; img-src * data: blob:; media-src * data: blob: ; connect-src 'self' ipc: cef-ipc: http://ipc.localhost ws: wss:{{#if isAndroid}} http://{{devServerHost}}:1420 http://10.0.2.2:1420 http://localhost:1420{{/if}} http://127.0.0.1:*; script-src 'self' 'unsafe-eval' 'unsafe-inline' 'nonce-kabegame-ejs-bridge'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; frame-src 'self' blob: data: about:;",
      {{!-- Tauri 默认会给打包 HTML 里的 <style> 标签自动注入随机 nonce 并加到 style-src,
           一旦 style-src 出现 nonce-source,浏览器会忽略该指令里的 'unsafe-inline'
           (对内联 style="" 属性同样生效,且属性没有 nonce 机制可用),
           导致 Vue :style 绑定等内联样式属性被 CSP 拦截。这里显式关闭 style-src 的自动
           nonce 注入,保留我们主动声明的 'unsafe-inline'。 --}}
      "dangerousDisableAssetCspModification": ["style-src"],
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    {{#unless isAndroid}}
    "targets": [
      {{#if isWindows}}"nsis"{{else if isMacOS}}"dmg"{{else if isLinux}}"deb"{{/if}}
    ],
    {{/unless}}
    {{!-- 只有非linux平台需要文件关联，linux用手动关联 desktop 文件 --}}
    {{#unless isLinux}}
    "fileAssociations": [
      {
        "ext": ["kgpg"],
        "name": "Kabegame Plugin Package",
        "description": "Kabegame Plugin Package",
        "role": "Viewer",
        "mimeType": "application/x-kabegame-kgpg"
      }
    ],
    {{/unless}}
    {{#if isWindows}}
    "windows": {
      "nsis": {
        "installerHooks": "nsis/installer-hooks.nsh",
        "languages": ["SimpChinese"],
        "installerIcon": "./icons/icon.ico"
      }
    },
    {{/if}}
    {{#if isMacOS}}
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": [{{#each macosFrameworks}}"{{this}}"{{#unless @last}},{{/unless}}{{/each}}],
      "files": {
        "MacOS/kabegame-cef-helper": "{{targetDir}}/release/kabegame-cef-helper"
      },
      "dmg": {
        "background": "dmg/background.jpg"
      }
    },
    {{/if}}
    {{#if isLinux}}
    "linux": {
      "deb": {
        "depends": [
          "libgtk-3-0", "libglib2.0-0", "libgdk-pixbuf-2.0-0", "libpango-1.0-0", "libcairo2", "libatk1.0-0", "libatk-bridge2.0-0", "libatspi2.0-0",
          "libx11-6", "libxcb1", "libxcomposite1", "libxdamage1", "libxext6", "libxfixes3", "libxrandr2", "libxkbcommon0",
          "libgbm1", "libdrm2",
          "libnss3", "libnspr4", "libssl3",
          "libasound2", "libcups2", "libdbus-1-3", "libudev1", "libexpat1", "libayatana-appindicator3-1",
          "zlib1g"
        ],
        "files": {
          {{#each linuxBins}}
          "/usr/lib/kabegame/{{this}}": "../../bin/linux/{{this}}",
          {{/each}}
          "/usr/lib/kabegame/kabegame-cef-helper": "{{targetDir}}/release/kabegame-cef-helper",
          "/usr/share/mime/packages/kabegame-kgpg.xml": "./deb/kabegame-kgpg.xml",
          "/usr/share/icons/hicolor/256x256/mimetypes/application-x-kabegame-kgpg.png": "./icons/icon.png"
        },
        "desktopTemplate": "./deb/kabegame.desktop",
        "postInstallScript": "./deb/postinst.sh",
        "postRemoveScript": "./deb/postrm.sh",
        "provides": ["kabegame"],
        "conflicts": ["kabegame"],
        "replaces": ["kabegame"]
      }
    },
    {{/if}}
    "resources": [
      "resources/**/*"
    ],
     {{!-- dev 用 icons/dev/ 下的图标(便于与正式版在 dock / 启动器区分);
          安卓 dev 的启动器图标另由 gen/android/app/src/debug/res 覆盖。 --}}
     "icon": [
      {{#if isDev}}
      "./icons/dev/icon.png",
      "./icons/dev/32x32.png",
      "./icons/dev/64x64.png",
      "./icons/dev/128x128.png",
      "./icons/dev/128x128@2x.png",
      "./icons/dev/icon.icns",
      "./icons/dev/icon.ico"
      {{else}}
      "./icons/icon.png",
      "./icons/32x32.png",
      "./icons/64x64.png",
      "./icons/128x128.png",
      "./icons/128x128@2x.png",
      "./icons/icon.icns",
      "./icons/icon.ico"
      {{/if}}
    ]
  }
}
