{
  "identifier": "main-capability",
  "description": "Main capability for Kabegame (workspace app-main)",
  "local": true,
  "windows": [{{#unless isAndroid}}"wallpaper", {{/unless}}"main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-set-always-on-top",
    "dialog:default",
    "opener:default",
    {{#if isAndroid}}
    "picker:default",
    "wallpaper:default",
    {{/if}}
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text"
  ]
}
