{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kabegame",
  "version": "3.5.0",
  "identifier": "app.kabegame",
  "build": {
    "beforeDevCommand": "bun run dev:frontend-main",
    "devUrl": "http://192.168.10.2:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "visible": true,
        "fullscreen": false,
        "resizable": true,
        "title": "Kabegame",
        "devtools": true
      }
    ],
    "security": {
      "capabilities": ["main-capability"],
      "csp": "default-src 'self' ipc: http://ipc.localhost http://192.168.10.2:1420 http://10.0.2.2:1420 http://localhost:1420; img-src * data: blob:; media-src * data: blob: ; connect-src 'self' ipc: http://ipc.localhost ws: wss: http://192.168.10.2:1420 http://10.0.2.2:1420 http://localhost:1420 http://127.0.0.1:*; script-src 'self' 'unsafe-eval' 'unsafe-inline' 'nonce-kabegame-ejs-bridge'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; frame-src 'self' blob: data: about:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "./icons/32x32.png", 
      "./icons/64x64.png", 
      "./icons/128x128.png", 
      "./icons/128x128@2x.png", 
      "./icons/icon.icns", 
      "./icons/icon.ico",
      "./icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": ["kgpg"],
        "name": "Kabegame Plugin Package",
        "description": "Kabegame Plugin Package",
        "role": "Viewer",
        "mimeType": "application/x-kabegame-kgpg"
      }
    ],
    "resources": [
      "resources/**/*"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/installer-hooks.nsh",
        "languages": ["SimpChinese"],
        "installerIcon": "../icons/icon.ico"
      }
    },
    "macOS": {
      "dmg": {
        "background": "dmg/background.jpg"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1"],
        "files": {
          "/usr/share/mime/packages/kabegame-kgpg.xml": "./deb/kabegame-kgpg.xml",
          "/usr/share/icons/hicolor/256x256/mimetypes/application-x-kabegame-kgpg.png": "../icons/icon.png"
        },
        "desktopTemplate": "./deb/kabegame.desktop",
        "postInstallScript": "./deb/postinst.sh",
        "postRemoveScript": "./deb/postrm.sh",
        "provides": ["kabegame"],
        "conflicts": ["kabegame"],
        "replaces": ["kabegame"]
      }
    }
  }
}
