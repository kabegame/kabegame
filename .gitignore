# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist-*
!dist-kabegame/
dist-kabegame/*
!dist-kabegame/.gitkeep
*.local

/release
/build

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store

# kabegame 的 tauri config 是动态生成的
# src-tauri/*/tauri.conf.json

# Tauri
target
# kabegame capability 由 handlebars 生成
src-tauri/kabegame/capabilities/main.json
# apps/kabegame/index.html 由 handlebars 生成（见 index.html.handlebars）
apps/kabegame/index.html
src-tauri/*/gen/schemas/*
# 插件 permissions 下的 schema.json 由 tauri_plugin::Builder 在 cargo build 时生成
src-tauri-plugins/**/permissions/schemas/schema.json
src-tauri/kabegame/resources/bin/*

# development data
/data
/cache

# Nx
.nx/cache
.nx/workspace-data
# .cursor/

# /test/

# FFmpeg 外树构建目录（bun run build:ffmpeg 产出）
third/FFmpeg-build

# 一些临时文件
/ignore

# Astro docs
apps/docs/dist
apps/docs/.astro
